# Profy Starter environment variables
# Copy to .env.local and fill in your values (.env.local is git-ignored)

# ---------- Platform URL ----------
# Same as profy.json -> platform.baseUrl; override here for CI/deploy without
# editing profy.json.
PLATFORM_BASE_URL=https://profy-test.agentspro.cn

# ---------- App Secret (sensitive) ----------
# Obtain from the Profy console. Used for dev gateway session exchange.
# Can also be set in profy.json -> platform.appSecret (do NOT commit to public repos).
PROFY_APP_SECRET=

# ---------- Optional: Base path override ----------
# Defaults to /webapps/{slug}. Only set if you need a custom sub-path.
# VITE_BASE_PATH=/webapps/my-app
