# Profy Starter 环境变量示例
# 复制为 .env.local 后按需填写（.env.local 已被 git 忽略，勿提交密钥）
#
# 多数变量可由根目录 profy.json 与 npm run dev（profy dev）注入；
# 此处用于本地覆盖、CI 或与 profy.json 互补（尤其是密钥）。

# ---------- 平台地址 ----------
# 与 profy.json → platform.baseUrl 一致；若 JSON 已填写则通常不必重复。
# 部署或流水线中可用此变量覆盖，无需改 profy.json。
PLATFORM_BASE_URL=https://profy-test.agentspro.cn

# ---------- 应用密钥（敏感）----------
# Profy 控制台获取。开发时网关与 /api 代理换票需要；也可写在 profy.json → platform.appSecret（同样勿提交仓库）。
PROFY_APP_SECRET=

# ---------- 可选：覆盖默认 basePath ----------
# 不设则 createNextConfig 使用 /webapps/{appCode}。自定义子路径时与 APP_PREFIX 二选一。
# NEXT_PUBLIC_BASE_PATH=/webapps/my-app
# APP_PREFIX=/webapps/my-app

# ---------- 可选：Next 内部地址（重写目标）----------
# 默认 http://127.0.0.1:{PORT}，PORT 默认 81（见 package.json / profy dev -p）。
# INTERNAL_NEXT_URL=http://127.0.0.1:81

# ---------- Profy CLI（profy login / deploy）----------
# 默认 https://profy-test.agentspro.cn；仅当使用其他环境时修改。
# PROFY_API_URL=https://profy-test.agentspro.cn
